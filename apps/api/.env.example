# --- MongoDB ---
MONGO_DB_CONNECTION_STRING=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=miniapp
# Collection name overrides (defaults shown). Use *_dev variants in development.
# MONGO_DB_COLLECTION_API_KEYS=api_keys
# MONGO_DB_COLLECTION_USERS=users
# MONGO_DB_COLLECTION_API_CALLS=api_calls
# MONGO_DB_COLLECTION_PRODUCTS=products
# MONGO_DB_COLLECTION_NEWS=news_items
# MONGO_DB_COLLECTION_SUGGESTIONS=suggestions

# --- Telegram ---
BOT_TOKEN=123456:abc...
# Public channel users are nudged to subscribe to (used by /v1/internal/channel-membership + /subscribe-request)
CHANNEL_ID=@ASLZAR_tilla
# Bot deeplink used to mint referral links
BOT_TELEGRAM_LINK=https://t.me/aslzaruzbot

# --- 1C ERP integration (used by internal /v1/internal/* routes consumed by the webapp) ---
ASLZAR_1C_BASE_URL=https://example.com/api/v1/
ASLZAR_1C_USERNAME=
ASLZAR_1C_PASSWORD=

# --- AmoCRM integration (used by /v1/internal/product-interest) ---
AMOCRM_BASE_URL=https://example.amocrm.ru
AMOCRM_API_TOKEN=
AMOCRM_PIPELINE_ID=

# --- CORS allowlist (comma-separated) ---
# Defaults: app.aslzarbot.uz, admin.aslzarbot.uz, http://localhost:3000, http://localhost:3002
# CORS_ALLOWED_ORIGINS=https://app.aslzarbot.uz,https://admin.aslzarbot.uz

# --- HTTP server port (Railway sets this automatically in prod) ---
# PORT=3001
